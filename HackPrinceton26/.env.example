# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Dedalus Machines ──────────────────────────────────────────────────────────
DEDALUS_API_KEY=your-dedalus-api-key
# Optional: override DCS base URL (defaults to https://dcs.dedaluslabs.ai)
# DEDALUS_DCS_URL=https://dcs.dedaluslabs.ai

# ── WhatsApp Cloud API (Meta) — outbreak alerts from VM 4 ─────────────────────
# Get these from https://developers.facebook.com → your WhatsApp Business app
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_ALERT_TO_NUMBER=+12345678901   # recipient with country code

# ── iMessage via Photon Spectrum — outbreak alerts from VM 4 ──────────────────
# Get these from https://app.photon.codes → your project
PHOTON_PROJECT_ID=your-photon-project-id
PHOTON_PROJECT_SECRET=your-photon-project-secret

# ── Internal security ─────────────────────────────────────────────────────────
# Shared secret for VM 4 → orchestrator /api/health/notify callback
ORCHESTRATOR_INTERNAL_SECRET=change-me-random-string
# Full URL of this orchestrator (used by VM 4 for the iMessage callback)
ORCHESTRATOR_URL=https://your-backend.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Mock mode — set to true to skip Dedalus VMs and return demo results ───────
# Useful for offline demos or when Dedalus credits are low.
# MOCK_MODE=true
